{
  "name": "capyai",
  "version": "0.2.0",
  "type": "module",
  "description": "Unofficial Capy.ai CLI for agent orchestration with quality gates",
  "bin": {
    "capy": "./bin/capy.js"
  },
  "scripts": {
    "build": "bun build bin/capy.ts --outdir dist --target node",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "bin/",
    "src/",
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PlawIO/capy-cli"
  },
  "keywords": [
    "capy",
    "ai",
    "coding-agent",
    "orchestration",
    "cli"
  ]
}
